{
  "version": "0.2.0",
  "configurations": [
    {
      // Run Extension: launches a new VS Code window (Extension Development Host)
      // with this extension loaded. Press F5 to launch, or use Run > Start Debugging.
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
